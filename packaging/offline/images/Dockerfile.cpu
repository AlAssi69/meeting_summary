FROM python:3.12-slim-bookworm

ENV DEBIAN_FRONTEND=noninteractive \
    PYTHONDONTWRITEBYTECODE=1 \
    PYTHONUNBUFFERED=1 \
    PIP_NO_CACHE_DIR=1 \
    PYTHONPATH=/opt/meeting-assistant/src \
    QT_QUICK_CONTROLS_STYLE=Basic \
    MEETING_ASSISTANT_OFFLINE_BUNDLE=1 \
    MEETING_ASSISTANT_SPEAKER_DIARIZATION=0 \
    MEETING_ASSISTANT_WHISPER_MODEL=large-v3-turbo \
    MEETING_ASSISTANT_WHISPER_ALIGN_LANGUAGE=ar \
    MEETING_ASSISTANT_WHISPER_DEVICE=cpu \
    MEETING_ASSISTANT_WHISPER_CACHE=/opt/meeting-assistant/models/whisper \
    HF_HOME=/opt/meeting-assistant/models/hf \
    HF_HUB_OFFLINE=0 \
    TRANSFORMERS_OFFLINE=0 \
    WHISPER_API_PORT=18080

WORKDIR /opt/meeting-assistant

RUN apt-get update && apt-get install -y --no-install-recommends \
    ffmpeg git curl ca-certificates \
    libgl1 libegl1 libxkbcommon0 libx11-6 libxext6 libxrender1 libxcb1 \
    libxcomposite1 libxdamage1 libxfixes3 libxi6 libxtst6 libdbus-1-3 \
    libfontconfig1 libfreetype6 libglib2.0-0 libnss3 libasound2 libpulse0 \
    && rm -rf /var/lib/apt/lists/*

COPY packaging/offline/images/requirements-container.txt ./packaging/offline/images/requirements-container.txt
COPY packaging/offline/images/requirements-cpu.txt ./packaging/offline/images/requirements-cpu.txt
RUN python -m pip install --upgrade pip setuptools wheel && \
    python -m pip install -r packaging/offline/images/requirements-container.txt && \
    python -m pip install -r packaging/offline/images/requirements-cpu.txt

COPY src ./src
COPY main.py ./main.py
COPY packaging ./packaging
COPY packaging/offline/scripts/entrypoint.sh /usr/local/bin/meeting-assistant-entrypoint.sh

RUN chmod +x /usr/local/bin/meeting-assistant-entrypoint.sh && \
    mkdir -p /opt/meeting-assistant/models/whisper /opt/meeting-assistant/models/hf

ARG PRELOAD_MODELS=1
ARG WHISPER_MODEL=large-v3-turbo
ARG WHISPER_ALIGN_LANGUAGE=ar
RUN if [ "$PRELOAD_MODELS" = "1" ]; then \
      MEETING_ASSISTANT_WHISPER_MODEL="$WHISPER_MODEL" \
      MEETING_ASSISTANT_WHISPER_ALIGN_LANGUAGE="$WHISPER_ALIGN_LANGUAGE" \
      HF_HUB_OFFLINE=0 TRANSFORMERS_OFFLINE=0 \
      python ./packaging/offline/scripts/preload_models.py ; \
    fi

ENV HF_HUB_OFFLINE=1 \
    TRANSFORMERS_OFFLINE=1 \
    HF_HUB_DISABLE_TELEMETRY=1

EXPOSE 18080

HEALTHCHECK --interval=15s --timeout=5s --start-period=120s --retries=5 \
  CMD curl -fsS "http://127.0.0.1:${WHISPER_API_PORT}/health" || exit 1

ENTRYPOINT ["/usr/local/bin/meeting-assistant-entrypoint.sh"]
