.venv/
.venv-host-client/
.env
.env.*
!.env.example
__pycache__/
*.py[cod]
*.sqlite
*.sqlite3
*.db

# Local meeting artifacts (audio, transcripts, summaries) — default output root
meeting_outputs/

# OS / IDE noise
.DS_Store
Thumbs.db
.idea/
.vscode/
*.log

# Python packaging / build outputs
dist/
build/
*.egg-info/

# Offline USB bundle — generated by packaging/offline/scripts/build_usb_bundle.ps1
packaging/offline/usb-bundle/

# PyInstaller host-client output (spec/scripts stay tracked under host-client/)
packaging/offline/host-client/dist/
packaging/offline/host-client/build/

# Tests / coverage (local only)
.pytest_cache/
htmlcov/
.coverage
coverage.xml

# Tool / package caches (pip, ruff, mypy, tox, Hypothesis, local Hub-style trees)
.mypy_cache/
.ruff_cache/
.tox/
.nox/
.hypothesis/
.cache/
.uv/
__pypackages__/

# Portable Whisper weights (keep models/.gitkeep; ignore hub cache contents)
models/whisper/

# NLTK corpora/tokenizers (e.g. punkt_tab from docs/TROUBLESHOOTING_NLTK_PUNKT_TAB.md Option B)
nltk_data/

# Large binaries / Docker exports (never commit)
*.exe
*.tar
*.tar.gz
*.tgz
*.zip
*.7z

# Generated bundle env (written beside usb-bundle by build_usb_bundle.ps1)
.env.bundle