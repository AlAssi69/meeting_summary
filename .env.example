# Copy to ".env" in the repository root (same folder as main.py). Never commit ".env".
# Load order: OS environment wins over .env (python-dotenv override=False).
# Full reference: README.md "Configuration (environment variables)", src/meeting_assistant/config.py,
# and src/meeting_assistant/services/output_paths.py (MEETING_ASSISTANT_OUTPUT_ROOT)

# --- Hugging Face (required when speaker diarization is enabled) ---
# Accept pyannote model terms on huggingface.co, then set one of:
# MEETING_ASSISTANT_HF_TOKEN=
# HF_ACCESS_TOKEN=
# HUGGING_FACE_HUB_TOKEN=
# HF_TOKEN=
# (In-app Settings can override env when the stored token is non-empty.)

# --- Speaker diarization (default on) ---
# MEETING_ASSISTANT_SPEAKER_DIARIZATION=1

# --- Ollama ---
# MEETING_ASSISTANT_OLLAMA_BASE_URL=http://127.0.0.1:11434
# MEETING_ASSISTANT_OLLAMA_HOST=localhost
# MEETING_ASSISTANT_OLLAMA_PORT=11434
# MEETING_ASSISTANT_OLLAMA_MODEL=gemma4:e4b128k

# --- Paths & data ---
# MEETING_ASSISTANT_PROJECT_ROOT=
# MEETING_ASSISTANT_DATA_DIR=
# MEETING_ASSISTANT_DB=
# MEETING_ASSISTANT_OUTPUT_ROOT=   # read in src/meeting_assistant/services/output_paths.py (not config.py)
# MEETING_ASSISTANT_WHISPER_CACHE=

# --- Backend / debug / trace ---
# MEETING_ASSISTANT_MOCK=0
# MEETING_ASSISTANT_DEBUG=0
# MEETING_ASSISTANT_TRACE_LEVEL=0
# MEETING_ASSISTANT_VERBOSE=0

# --- Whisper ASR & alignment (see README for full list) ---
# MEETING_ASSISTANT_WHISPER_MODEL=large-v3
# MEETING_ASSISTANT_WHISPER_LANGUAGE=auto
# Default in code is ar; use auto/none/empty to follow ASR-detected language for alignment:
# MEETING_ASSISTANT_WHISPER_ALIGN_LANGUAGE=ar
# MEETING_ASSISTANT_WHISPER_DEVICE=cuda
# MEETING_ASSISTANT_WHISPER_BEAM_SIZE=7
# MEETING_ASSISTANT_WHISPERX_BATCH_SIZE=8
# MEETING_ASSISTANT_WHISPER_COMPUTE_TYPES=float16,int8
# MEETING_ASSISTANT_TRANSCRIPT_JARGON_NORMALIZE=0
# MEETING_ASSISTANT_WHISPER_CONDITION_ON_PREVIOUS_TEXT=0
# MEETING_ASSISTANT_WHISPER_NO_SPEECH_THRESHOLD=0.75
# MEETING_ASSISTANT_WHISPER_COMPRESSION_RATIO_THRESHOLD=2.4
# MEETING_ASSISTANT_WHISPERX_DROP_SEGMENT_MIN_AVG_LOGPROB=
# MEETING_ASSISTANT_WHISPERX_ASR_COMPRESSION_MIN_CHARS=24
# MEETING_ASSISTANT_WHISPER_MIN_BIN_BYTES=

# --- FFmpeg & audio preprocessing ---
# MEETING_ASSISTANT_FFMPEG_PATH=
# MEETING_ASSISTANT_AUDIO_PREP_ENABLED=1
# MEETING_ASSISTANT_AUDIO_PREP_KEEP_TEMP=0
# MEETING_ASSISTANT_AUDIO_PREP_FFMPEG_TIMEOUT_SEC=7200
# MEETING_ASSISTANT_FFMPEG_AFILTER=
# MEETING_ASSISTANT_AUDIO_PREP_HIGHPASS_HZ=80
# MEETING_ASSISTANT_AUDIO_PREP_ACOMP_THRESHOLD_DB=-18
# MEETING_ASSISTANT_AUDIO_PREP_ACOMP_RATIO=3
# MEETING_ASSISTANT_AUDIO_PREP_ACOMP_ATTACK_MS=20
# MEETING_ASSISTANT_AUDIO_PREP_ACOMP_RELEASE_MS=250
# MEETING_ASSISTANT_AUDIO_PREP_ACOMP_MAKEUP_DB=2
# MEETING_ASSISTANT_AUDIO_PREP_LOUDNORM_ENABLED=1
# MEETING_ASSISTANT_AUDIO_PREP_LOUDNORM_I=-16
# MEETING_ASSISTANT_AUDIO_PREP_LOUDNORM_TP=-1.5
# MEETING_ASSISTANT_AUDIO_PREP_LOUDNORM_LRA=11
# MEETING_ASSISTANT_MOCK_DELAY=0.45
